# Environment variables for Emotional Support Website
# Copy this file to .env and fill in your values

# Choose ONE of the following API providers:

# Option 1: Google Gemini (Recommended for Hong Kong) - FREE!
# Get key from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your-key-here

# Option 2: OpenAI (ChatGPT) - Available in Hong Kong, Taiwan, etc.
# Get key from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-proj-your-key-here

# Option 3: Claude (Anthropic) - For other regions
# Get key from: https://console.anthropic.com/
# CLAUDE_API_KEY=sk-ant-your-key-here

# Optional: Set to "local" to disable AI and use fallback mode
# AI_MODE=local
